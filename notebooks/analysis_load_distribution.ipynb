# Cell 1: Imports
import pandas as pd
import plotly.express as px
import plotly.graph_objects as go
from sqlalchemy import create_engine
import requests

# Cell 2: Fetch Data from API
response = requests.get("http://localhost:8000/api/v1/components/")
components = response.json()

# Cell 3: Process Data
df = pd.DataFrame([{
    'component': c['name'],
    'mass': c['mass'],
    'total_force': sum(lc['force_vector'][0]**2 + lc['force_vector'][1]**2 + lc['force_vector'][2]**2)**0.5
    for lc in c['load_cases']
} for c in components])

# Cell 4: Interactive Plot
fig = px.scatter(df, x='mass', y='total_force', color='component', size='mass',
                 hover_data=['component'], title='Component Mass vs Total Load Force')
fig.show()
